# Profile Genie Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=profilegenie
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Full connection string (auto-constructed from above values)
# ConnectionStrings__profilegenie-db=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# ===========================================
# API Configuration
# ===========================================
API_PORT=5000
API_HTTPS_PORT=5001
ASPNETCORE_ENVIRONMENT=Development

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=5100
FRONTEND_HTTPS_PORT=5101

# ===========================================
# Aspire Configuration (optional)
# ===========================================
ASPIRE_DASHBOARD_PORT=18888

# ===========================================
# Redis Configuration (optional)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
